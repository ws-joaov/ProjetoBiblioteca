<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Login - Biblioteca</title>
  <link rel="stylesheet" href="/styles/site.css" />
</head>
<body>
  <main class="main" style="min-height:100vh; display:grid; place-items:center;">
    <div class="grid" style="width:min(1100px, 96vw);">
    <section class="panel">
      <span class="badge-pill">Login</span>
      <h1>Bem-vindo à biblioteca</h1>
      <p>Faça login para obter seu token JWT e usar as rotas protegidas, como criação de livros e exclusão de avaliações.</p>
      <form id="loginForm">
        <label class="label" for="email">E-mail</label>
        <input class="input" id="email" name="email" type="email" required />

        <label class="label" for="senha">Senha</label>
        <input class="input" id="senha" name="senha" type="password" required />

        <button class="btn" type="submit">Entrar</button>
      </form>
      <div id="tokenBox" class="status" hidden></div>
      <p class="small">Após o login, use os links para acessar usuários, livros e avaliações.</p>
      <button class="btn secondary" type="button" onclick="location.href='/usuarios'">Ir para usuários</button>
    </section>

    <section class="card">
      <span class="badge-pill">Registro</span>
      <h1>Cadastre um novo usuário</h1>
      <p>Crie sua conta para usar o sistema e acessar as áreas do front.</p>
      <form id="registerForm">
        <label class="label" for="nome">Nome</label>
        <input class="input" id="nome" name="nome" type="text" required />

        <label class="label" for="emailRegistro">E-mail</label>
        <input class="input" id="emailRegistro" name="emailRegistro" type="email" required />

        <label class="label" for="senhaRegistro">Senha</label>
        <input class="input" id="senhaRegistro" name="senhaRegistro" type="password" required />

        <button class="btn" type="submit">Criar conta</button>
      </form>
      <div id="registerBox" class="status" hidden></div>
    </section>
    </div>
  </main>

  <script>
    const form = document.getElementById('loginForm');
    const registerForm = document.getElementById('registerForm');
    const tokenBox = document.getElementById('tokenBox');
    const registerBox = document.getElementById('registerBox');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const payload = {
        email: document.getElementById('email').value,
        senha: document.getElementById('senha').value
      };

      const response = await fetch('/api/usuarios/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const data = await response.json();
      if (!response.ok) {
        tokenBox.hidden = false;
        tokenBox.textContent = data.erro || 'Falha no login';
        return;
      }

      tokenBox.hidden = false;
      tokenBox.textContent = 'Token JWT: ' + data.token;
      localStorage.setItem('biblioteca_token', data.token);
      window.location.href = '/usuarios';
    });

    registerForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const payload = {
        nome: document.getElementById('nome').value,
        email: document.getElementById('emailRegistro').value,
        senha: document.getElementById('senhaRegistro').value
      };

      const response = await fetch('/api/usuarios', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const data = await response.json();
      registerBox.hidden = false;
      registerBox.textContent = response.ok
        ? 'Conta criada com sucesso para ' + data.email
        : (data.erro || 'Erro no cadastro');
    });
  </script>
</body>
</html>
